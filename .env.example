# Environment variables for the phishing detection lab.
#
# Copy this file to `.env` and fill in the real values.
# NEVER commit `.env` to version control — it is listed in `.gitignore`.

# ─── Lab Network ─────────────────────────────────────────────────────────────
# Internal IP address of the GoPhish / mail server host
LAB_HOST_IP=<YOUR_LAB_HOST_IP>

# Internal IP address of the Wazuh manager
WAZUH_MANAGER_IP=<YOUR_WAZUH_MANAGER_IP>

# Internal IP address of the Windows workstation (target)
WINDOWS_WORKSTATION_IP=<YOUR_WINDOWS_WORKSTATION_IP>

# ─── GoPhish ─────────────────────────────────────────────────────────────────
# Admin UI credentials (change before first launch)
GOPHISH_ADMIN_USER=admin
GOPHISH_ADMIN_PASSWORD=<CHANGE_ME>

# GoPhish API key (generated after first login)
GOPHISH_API_KEY=<YOUR_GOPHISH_API_KEY>

# Listening address for the GoPhish admin panel (restrict to localhost or VPN)
GOPHISH_ADMIN_LISTEN_URL=127.0.0.1:3333

# ─── Postfix (SMTP relay) ─────────────────────────────────────────────────────
# SMTP relay host used by Postfix
SMTP_RELAY_HOST=<YOUR_SMTP_RELAY_HOST>
SMTP_RELAY_PORT=587

# SASL credentials for the upstream relay (stored in sasl_passwd — never commit)
SMTP_RELAY_USER=<YOUR_SMTP_RELAY_USER>
SMTP_RELAY_PASSWORD=<YOUR_SMTP_RELAY_PASSWORD>

# ─── Dovecot ─────────────────────────────────────────────────────────────────
# Test mailbox credentials for end-to-end delivery validation
DOVECOT_TEST_USER=testuser
DOVECOT_TEST_PASSWORD=<CHANGE_ME>

# ─── Wazuh ───────────────────────────────────────────────────────────────────
# Wazuh agent registration password (set in authd.pass — never commit)
WAZUH_AGENT_AUTH_PASSWORD=<CHANGE_ME>

# Wazuh API credentials
WAZUH_API_USER=wazuh
WAZUH_API_PASSWORD=<CHANGE_ME>

# ─── TLS / Certificates ──────────────────────────────────────────────────────
# Paths to TLS key and certificate on the local host (never commit the files)
TLS_KEY_PATH=/etc/ssl/private/lab.key
TLS_CERT_PATH=/etc/ssl/certs/lab.crt
